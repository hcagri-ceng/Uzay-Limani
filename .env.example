# WeatherAPI.com — https://www.weatherapi.com/
WEATHER_API_KEY=your_key_here

# Anahtar yokken veya sadece UI testi için: true yapın (üretimde false).
USE_MOCK_WEATHER=false

# Rakım: önce OpenTopoData (SRTM), yedek Open Elevation
# OPENTOPODATA_API_BASE_URL=https://api.opentopodata.org/v1
# ELEVATION_OPENTOPODATA_DATASET=srtm30m
# ELEVATION_PREFER_OPENTOPODATA=true
# ELEVATION_HTTP_TIMEOUT_S=28
# OPEN_ELEVATION_BASE_URL=https://api.open-elevation.com/api/v1
# ELEVATION_SAMPLE_RADIUS_M=150
# MAX_TERRAIN_SLOPE_PERCENT=2
# USE_MOCK_ELEVATION=false

# Tablo eşikleri (kt / m / derece)
# WIND_TAKEOFF_MAX_KNOTS=30
# WIND_LANDING_MAX_KNOTS=18
# MAX_WAVE_HEIGHT_M=2.5
# IDEAL_EQUATOR_LATITUDE_MAX_DEG=28

# Overpass — virgülle birden fazla interpreter (429/504 yedeği)
# OVERPASS_INTERPRETER_URL=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
# LOGISTICS_PORT_RAIL_RADIUS_M=50000
# LOGISTICS_MOTORWAY_RADIUS_M=20000
# LOGISTICS_INCLUDE_PIERS=false
# OVERPASS_TIMEOUT_S=120
# OVERPASS_REQUEST_GAP_S=0.35
# USE_MOCK_LOGISTICS=false
